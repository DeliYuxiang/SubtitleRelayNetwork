{
  "name": "srn-worker",
  "version": "3.0.1",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:test": "./start_local.sh",
    "dev:test:pull": "./start_local.sh --pull",
    "test:setup": "wrangler d1 migrations apply DB --local -c wrangler.test.jsonc",
    "db:pull": "source .env && npx wrangler d1 export $SRN_D1_NAME --remote --output=.remote_dump.sql && npx wrangler d1 execute DB --local --file=.remote_dump.sql -c wrangler.test.jsonc && rm .remote_dump.sql",
    "db:export": "npx wrangler d1 export DB --local -c wrangler.test.jsonc --output=../srnrelay/ts/tests/snapshot.sqlite",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@srn/client": "npm:@deliyuxiang/srn-client@^0.1.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.12",
    "uuid": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.21",
    "@cloudflare/workers-types": "^4.20260414.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "typescript": "^6.0.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.82.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write"
    ]
  }
}